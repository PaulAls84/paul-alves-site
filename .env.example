# ─────────────────────────────────────────────────────────
# Variables d'environnement — Paul Alves Site
# Copie ce fichier en `.env` et remplace les valeurs vides.
# ─────────────────────────────────────────────────────────

# ── Systeme.io (newsletter + contact CRM) ──
# Récupère ta clé sur https://systeme.io > Profil > API
SYSTEME_IO_API_KEY=

# ── Google Analytics 4 ──
# Format : G-XXXXXXXXXX
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Google Search Console (optionnel) ──
# Code de vérification HTML méta-tag
PUBLIC_GSC_VERIFICATION=

# ── Resend (formulaire de contact) ──
# 1. Crée un compte sur https://resend.com
# 2. Vérifie ton domaine dans "Domains"
# 3. Crée une clé API dans "API Keys" (re_...)
RESEND_API_KEY=

# Adresse qui reçoit les messages du formulaire contact
CONTACT_TO_EMAIL=hello@paul-alves.fr

# Adresse d'envoi (doit appartenir à un domaine vérifié dans Resend)
CONTACT_FROM_EMAIL=hello@paul-alves.fr
