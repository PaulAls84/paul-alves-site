---
import '../styles/global.css'
import MobileBar from '../components/MobileBar.astro'
import CookieBanner from '../components/CookieBanner.astro'

interface Props {
  title?: string
  description?: string
  image?: string
  schema?: string
  ogType?: 'website' | 'article'
  publishedAt?: string
  author?: string
  section?: string
}

const {
  title = 'Paul Alves — Développeur Web & Consultant SEO à Soissons',
  description = "J'aide les entreprises à se développer en ligne grâce à des sites web sur mesure, rapides et optimisés pour le SEO.",
  image = '/assets/hero-visual.png',
  schema,
  ogType = 'website',
  publishedAt,
  author = 'Paul Alves',
  section,
} = Astro.props

const gaId  = import.meta.env.PUBLIC_GA_MEASUREMENT_ID
const gscId = import.meta.env.PUBLIC_GSC_VERIFICATION

const siteURL    = 'https://paul-alves.fr'
const canonicalURL = new URL(Astro.url.pathname, siteURL).href
const imageURL     = new URL(image, siteURL).href

const localBusinessSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "ProfessionalService"],
  "name": "Paul Alves",
  "description": "Développeur Web & Consultant SEO freelance basé à Soissons. Création de sites WordPress sur mesure, refonte, optimisation SEO et performances. Disponible partout en France.",
  "url": siteURL,
  "logo": `${siteURL}/assets/logo-full.png`,
  "image": `${siteURL}/assets/photo-paul.png`,
  "email": "hello@paul-alves.fr",
  "telephone": "+33656666684",
  "priceRange": "€€",
  "currenciesAccepted": "EUR",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "3 rue des Longues Raies",
    "postalCode": "02200",
    "addressLocality": "Soissons",
    "addressRegion": "Hauts-de-France",
    "addressCountry": "FR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 49.3814,
    "longitude": 3.3236
  },
  "areaServed": {
    "@type": "Country",
    "name": "France"
  },
  "knowsAbout": [
    "WordPress", "WooCommerce", "SEO", "Référencement naturel",
    "Création de site web", "Optimisation des performances web",
    "Core Web Vitals", "Google Search Console", "Marketing de contenu"
  ],
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "09:00",
      "closes": "18:00"
    }
  ],
  "sameAs": [
    "https://linkedin.com/in/paul-alves"
  ]
})

const personSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Paul Alves",
  "jobTitle": "Développeur Web & Consultant SEO",
  "description": "Freelance spécialisé WordPress et SEO. A généré plus d'un million de visiteurs organiques sur son propre blog avant d'accompagner les entreprises dans leur développement web et leur référencement.",
  "url": siteURL,
  "image": `${siteURL}/assets/photo-paul.png`,
  "email": "hello@paul-alves.fr",
  "telephone": "+33656666684",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Soissons",
    "addressRegion": "Hauts-de-France",
    "addressCountry": "FR"
  },
  "knowsAbout": [
    "WordPress", "WooCommerce", "SEO", "Référencement naturel",
    "Création de site web", "Optimisation des performances web",
    "Core Web Vitals", "Google Search Console", "Marketing de contenu"
  ],
  "sameAs": [
    "https://linkedin.com/in/paul-alves"
  ],
  "worksFor": {
    "@type": "Organization",
    "name": "Paul Alves",
    "url": siteURL
  }
})
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/png" href="/assets/logo-mark.png" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={imageURL} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content={ogType} />
  <meta property="og:locale" content="fr_FR" />
  <meta property="og:site_name" content="Paul Alves" />
  {ogType === 'article' && publishedAt && <meta property="article:published_time" content={publishedAt} />}
  {ogType === 'article' && <meta property="article:author" content={author} />}
  {ogType === 'article' && section && <meta property="article:section" content={section} />}

  <!-- Twitter Cards -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={imageURL} />
  <meta name="twitter:site" content="@paul_alves" />

  <meta name="robots" content="index, follow" />

  <!-- Google Search Console vérification -->
  {gscId && <meta name="google-site-verification" content={gscId} />}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" />

  <!-- Schema.org — LocalBusiness + Person (toutes les pages) -->
  <script type="application/ld+json" set:html={localBusinessSchema} />
  <script type="application/ld+json" set:html={personSchema} />

  <!-- Schema.org — spécifique à la page (Article, FAQ, etc.) -->
  {schema && <script type="application/ld+json" set:html={schema} />}

  <!-- Google tag (gtag.js) avec Consent Mode v2 — denied par défaut -->
  {gaId && (
    <>
      <script define:vars={{ gaId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        window.gtag = gtag;
        // Consent Mode v2 : tout refusé par défaut, mis à jour après accord utilisateur
        gtag('consent', 'default', {
          ad_storage:           'denied',
          ad_user_data:         'denied',
          ad_personalization:   'denied',
          analytics_storage:    'denied',
          functionality_storage:'granted',
          security_storage:     'granted',
          wait_for_update:      500,
        });
        gtag('js', new Date());
        gtag('config', gaId, { anonymize_ip: true });
      </script>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
    </>
  )}
</head>
<body>
  <slot />
  <MobileBar />
  <CookieBanner />
</body>
</html>
