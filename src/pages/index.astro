---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Hero from '../components/Hero.astro'
import Services from '../components/Services.astro'
import About from '../components/About.astro'
import Stats from '../components/Stats.astro'
import Projects from '../components/Projects.astro'
import Testimonials from '../components/Testimonials.astro'
import BlogPreview from '../components/BlogPreview.astro'
import Newsletter from '../components/Newsletter.astro'
import CTABand from '../components/CTABand.astro'
import Footer from '../components/Footer.astro'

import { createReader } from '@keystatic/core/reader'
import keystaticConfig from '../../keystatic.config'

let posts: any[] = []
try {
  const reader = createReader(process.cwd(), keystaticConfig)
  const slugs = await reader.collections.blog.list()
  const entries = await Promise.all(
    slugs.map(async (slug) => {
      const entry = await reader.collections.blog.read(slug)
      return entry ? { slug, ...entry } : null
    })
  )
  posts = entries
    .filter(Boolean)
    .sort((a, b) =>
      new Date(b!.publishedAt ?? 0).getTime() - new Date(a!.publishedAt ?? 0).getTime()
    )
    .slice(0, 3)
    .map(p => ({
      slug: p!.slug,
      title: typeof p!.title === 'object' ? (p!.title as any).value ?? '' : p!.title ?? '',
      description: p!.description ?? '',
      publishedAt: p!.publishedAt ?? '',
      category: p!.category ?? '',
      image: p!.image ?? '',
    }))
} catch {
  // No posts yet
}
---

<Layout>
  <Nav currentPath="/" />
  <Hero />
  <Services />
  <About />
  <Stats />
  <Projects />
  <Testimonials />
  <BlogPreview posts={posts} />
  <Newsletter />
  <CTABand />
  <Footer />
</Layout>

<!-- Cal.com embed -->
<script>
  (function(C: any, A: string, L: string) {
    const p = (a: any, ar: any) => a.q.push(ar)
    const d = (C as any).document
    ;(C as any).Cal = (C as any).Cal || function() {
      const cal = (C as any).Cal
      const ar = arguments as any
      if (!cal.loaded) {
        cal.ns = {}; cal.q = cal.q || []
        d.head.appendChild(d.createElement('script')).src = A
        cal.loaded = true
      }
      if (ar[0] === L) {
        const api: any = function() { p(api, arguments) }
        const namespace = ar[1]
        api.q = api.q || []
        typeof namespace === 'string' ? (cal.ns[namespace] = api) && p(api, ar) : p(cal, ar)
        return
      }
      p(cal, ar)
    }
  })(window, 'https://app.cal.eu/embed/embed.js', 'init')

  ;(window as any).Cal('init', 'audit-offert', { origin: 'https://cal.eu' })
  ;(window as any).Cal.ns['audit-offert']('ui', {
    styles: { branding: { brandColor: '#d4a44a' } },
    hideEventTypeDetails: false,
    layout: 'month_view',
  })
</script>
