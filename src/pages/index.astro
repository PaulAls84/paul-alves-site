---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Hero from '../components/Hero.astro'
import Services from '../components/Services.astro'
import About from '../components/About.astro'
import Stats from '../components/Stats.astro'
import Projects from '../components/Projects.astro'
import Testimonials from '../components/Testimonials.astro'
import BlogPreview from '../components/BlogPreview.astro'
import Newsletter from '../components/Newsletter.astro'
import CTABand from '../components/CTABand.astro'
import Footer from '../components/Footer.astro'
import CalLoader from '../components/CalLoader.astro'

import { createReader } from '@keystatic/core/reader'
import keystaticConfig from '../../keystatic.config'

let posts: any[] = []
try {
  const reader = createReader(process.cwd(), keystaticConfig)
  const slugs = await reader.collections.blog.list()
  const entries = await Promise.all(
    slugs.map(async (slug) => {
      try {
        const entry = await reader.collections.blog.read(slug)
        return entry ? { slug, ...entry } : null
      } catch {
        return null // un article corrompu ne doit pas faire tomber tout le blog
      }
    })
  )
  posts = entries
    .filter(Boolean)
    // Articles « À la une » d'abord, puis les plus récents pour compléter
    .sort((a, b) =>
      (b!.featured ? 1 : 0) - (a!.featured ? 1 : 0) ||
      new Date(b!.publishedAt ?? 0).getTime() - new Date(a!.publishedAt ?? 0).getTime()
    )
    .slice(0, 3)
    .map(p => ({
      slug: p!.slug,
      title: typeof p!.title === 'object' ? (p!.title as any).value ?? '' : p!.title ?? '',
      description: p!.description ?? '',
      publishedAt: p!.publishedAt ?? '',
      category: p!.category ?? '',
      image: p!.image ?? '',
    }))
} catch {
  // No posts yet
}
---

<Layout>
  <Nav currentPath="/" />
  <Hero />
  <Services />
  <About />
  <Stats />
  <Projects />
  <Testimonials />
  <BlogPreview posts={posts} />
  <Newsletter />
  <CTABand />
  <Footer />
</Layout>

<!-- Cal.com embed -->
<CalLoader />
