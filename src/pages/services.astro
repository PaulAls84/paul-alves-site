---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Testimonials from '../components/Testimonials.astro'
import CTABand from '../components/CTABand.astro'
import Footer from '../components/Footer.astro'
import CalLoader from '../components/CalLoader.astro'

const services = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>`,
    title: 'Création de site WordPress',
    price: 'À partir de 1 500€',
    duration: '2 – 4 semaines',
    features: [
      'Design personnalisé et responsive',
      'Intégration de fonctionnalités avancées',
      'Formation à l\'administration',
      'Optimisation SEO de base',
      'Conformité RGPD',
      'Support post-lancement 30 jours',
    ],
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 12a9 9 0 1 1-6.22-8.56"/><polyline points="21 3 21 9 15 9"/></svg>`,
    title: 'Refonte de site existant',
    price: 'À partir de 1 200€',
    duration: '2 – 3 semaines',
    features: [
      'Audit complet de l\'existant',
      'Nouveau design moderne',
      'Migration de contenu sécurisée',
      'Amélioration de l\'UX/UI',
      'Optimisation des performances',
      'Redirections 301 configurées',
    ],
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>`,
    title: 'Optimisation SEO',
    price: 'À partir de 800€',
    duration: '1 – 2 semaines',
    features: [
      'Audit SEO technique complet',
      'Recherche de mots-clés stratégiques',
      'Optimisation on-page',
      'Amélioration de la vitesse',
      'Configuration Search Console',
      'Rapport mensuel de suivi',
    ],
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    title: 'Optimisation des performances',
    price: 'À partir de 600€',
    duration: '3 – 5 jours',
    features: [
      'Audit de performance détaillé',
      'Optimisation des images (WebP)',
      'Mise en cache avancée',
      'Minification CSS / JS',
      'CDN et lazy loading',
      'Score PageSpeed 90+',
    ],
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Sécurisation WordPress',
    price: 'À partir de 400€',
    duration: '1 – 2 jours',
    features: [
      'Audit de sécurité complet',
      'Installation firewall avancé',
      'Sauvegardes automatiques',
      'Certificat SSL',
      'Monitoring 24/7',
      'Rapport de sécurité détaillé',
    ],
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0"/><path d="M12 8v4l3 3"/></svg>`,
    title: 'Maintenance mensuelle',
    price: '150€ / mois',
    duration: 'Abonnement',
    features: [
      'Mises à jour WordPress & plugins',
      'Sauvegardes hebdomadaires',
      'Monitoring de disponibilité',
      'Corrections de bugs',
      'Support technique prioritaire',
      'Rapport mensuel détaillé',
    ],
  },
]

const steps = [
  { num: '01', title: 'Découverte', desc: 'Un appel gratuit de 30 minutes pour comprendre votre projet, vos objectifs et votre cible.' },
  { num: '02', title: 'Proposition', desc: 'Un devis détaillé et transparent sous 24h, avec planning et livrables clairement définis.' },
  { num: '03', title: 'Réalisation', desc: 'Développement itératif avec des points d\'avancement réguliers pour valider ensemble chaque étape.' },
  { num: '04', title: 'Livraison', desc: 'Mise en ligne, formation à l\'administration et support post-lancement inclus.' },
]

const faqs = [
  {
    q: 'Combien coûte la création d\'un site WordPress ?',
    a: 'La création d\'un site WordPress sur mesure démarre à 1 500€ pour un site vitrine. Le tarif varie selon la complexité, le nombre de pages et les fonctionnalités souhaitées (e-commerce, formulaires avancés, animations…). Je fournis un devis détaillé et transparent sous 24h après notre premier échange.',
  },
  {
    q: 'Combien de temps faut-il pour créer un site web ?',
    a: 'La durée moyenne est de 2 à 4 semaines pour un site vitrine, et de 2 à 3 semaines pour une refonte. Le planning précis est défini dès la proposition commerciale avec des jalons clairs pour valider chaque étape ensemble. Une optimisation SEO ou de performances peut être réalisée en 3 à 5 jours.',
  },
  {
    q: 'Travaillez-vous avec des clients en dehors de Soissons ?',
    a: 'Absolument. J\'interviens partout en France. Le travail s\'effectue majoritairement à distance via des outils collaboratifs (visioconférence, partage d\'écran, espaces de travail partagés). Je me déplace ponctuellement si le projet le justifie.',
  },
  {
    q: 'Proposez-vous une maintenance après la création du site ?',
    a: 'Oui. Je propose une formule de maintenance mensuelle à 150€/mois qui inclut les mises à jour WordPress et plugins, les sauvegardes hebdomadaires, le monitoring de disponibilité 24h/24, les corrections de bugs et un support technique prioritaire avec rapport mensuel.',
  },
  {
    q: 'Mon site existant peut-il être repris et amélioré ?',
    a: 'Oui, je propose une prestation de refonte de site existant à partir de 1 200€. Elle inclut un audit complet de l\'existant, un nouveau design, la migration sécurisée du contenu, l\'amélioration de l\'UX et la configuration des redirections 301 pour préserver votre référencement.',
  },
  {
    q: 'Quel est votre délai de réponse ?',
    a: 'Je m\'engage à répondre à toutes les demandes dans les 24h en semaine. Vous pouvez également réserver directement un appel de découverte gratuit via mon calendrier en ligne pour convenir d\'un créneau qui vous convient.',
  },
]

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.a,
    },
  })),
})
---

<Layout
  title="Services WordPress & SEO — Paul Alves"
  description="Création de site WordPress, refonte, optimisation SEO, performances et maintenance. Des solutions sur mesure à partir de 400€. Basé à Soissons, disponible partout en France."
  schema={faqSchema}
>
  <Nav currentPath="/services" />

  <!-- Hero -->
  <section class="services-hero">
    <div class="wrap">
      <p class="eyebrow">Mes services</p>
      <h1>Des solutions digitales pour votre <span class="accent">réussite</span> en ligne</h1>
      <p class="lede">
        Création, refonte, SEO, performances ou maintenance — j'interviens sur toutes les dimensions
        de votre présence web WordPress pour générer des résultats concrets et durables.
      </p>
      <div class="hero-ctas">
        <a
          href="#"
          data-cal-link="paul-alves/audit-offert"
          data-cal-namespace="audit-offert"
          data-cal-config='{"layout":"month_view"}'
          class="btn btn-gold"
        >
          Réserver un appel gratuit
        </a>
        <a href="tel:+33656666684" class="btn btn-ghost-light hero-tel">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
          </svg>
          06 56 66 66 84
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats">
    <div class="wrap">
      <div class="stats-grid">
        <div class="stat">
          <div class="stat-num">5+</div>
          <div class="stat-label">Années d'expérience</div>
        </div>
        <div class="stat">
          <div class="stat-num">50+</div>
          <div class="stat-label">Projets réalisés</div>
        </div>
        <div class="stat">
          <div class="stat-num">40+</div>
          <div class="stat-label">Clients satisfaits</div>
        </div>
        <div class="stat">
          <div class="stat-num">24h</div>
          <div class="stat-label">Temps de réponse</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services grid -->
  <section class="services-section" id="services-grid">
    <div class="wrap">
      <p class="section-eyebrow">Ce que je propose</p>
      <h2 class="section-title">Choisissez la <span class="accent">prestation</span> adaptée à vos besoins</h2>

      <div class="srv-grid">
        {services.map(s => (
          <div class="srv-card">
            <div class="srv-header">
              <div class="srv-icon" set:html={s.icon} />
              <div class="srv-meta">
                <span class="srv-price">{s.price}</span>
                <span class="srv-duration">{s.duration}</span>
              </div>
            </div>
            <h3>{s.title}</h3>
            <ul class="srv-features">
              {s.features.map(f => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <a
              href="#"
              data-cal-link="paul-alves/audit-offert"
              data-cal-namespace="audit-offert"
              data-cal-config='{"layout":"month_view"}'
              class="btn btn-outline srv-cta"
            >
              Demander un devis
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="process-section">
    <div class="wrap">
      <p class="section-eyebrow">Comment ça marche</p>
      <h2 class="section-title">Un processus simple et <span class="accent">transparent</span></h2>
      <div class="process-grid">
        {steps.map(step => (
          <div class="process-step">
            <div class="step-num">{step.num}</div>
            <h3>{step.title}</h3>
            <p>{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section" id="faq">
    <div class="wrap">
      <p class="section-eyebrow">FAQ</p>
      <h2 class="section-title">Questions <span class="accent">fréquentes</span></h2>
      <div class="faq-list">
        {faqs.map((f, i) => (
          <details class="faq-item" name="faq">
            <summary class="faq-question">
              <span>{f.q}</span>
              <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </summary>
            <div class="faq-answer">
              <p>{f.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Testimonials />
  <CTABand />
  <Footer />
</Layout>

<CalLoader />

<style>
  /* ── Hero ─────────────────────────────────────── */
  .services-hero {
    background: var(--navy);
    padding: 120px 0 80px;
    text-align: center;
  }
  .services-hero .eyebrow {
    color: var(--gold);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .14em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .services-hero h1 {
    font-family: var(--serif);
    font-size: clamp(2rem, 5vw, 3.2rem);
    color: #fff;
    max-width: 700px;
    margin: 0 auto 20px;
    line-height: 1.2;
  }
  .services-hero .lede {
    color: rgba(255,255,255,.75);
    font-size: 17px;
    max-width: 560px;
    margin: 0 auto 36px;
    line-height: 1.7;
  }
  .hero-ctas {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── Stats ────────────────────────────────────── */
  .stats {
    background: var(--cream);
    padding: 60px 0;
    border-bottom: 1px solid var(--line);
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    text-align: center;
  }
  .stat-num {
    font-family: var(--serif);
    font-size: 2.4rem;
    font-weight: 700;
    color: var(--navy);
    line-height: 1;
  }
  .stat-label {
    font-size: 13px;
    color: var(--ink-2);
    margin-top: 6px;
  }

  /* ── Services grid ────────────────────────────── */
  .services-section {
    padding: 100px 0;
    background: #fff;
  }
  .srv-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-top: 56px;
  }
  .srv-card {
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition: box-shadow .2s, transform .2s;
  }
  .srv-card:hover {
    box-shadow: 0 12px 40px rgba(10,29,54,.09);
    transform: translateY(-3px);
  }
  .srv-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
  }
  .srv-icon {
    width: 48px;
    height: 48px;
    background: var(--cream);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--navy);
    flex-shrink: 0;
  }
  .srv-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }
  .srv-price {
    font-weight: 700;
    font-size: 14px;
    color: var(--gold);
  }
  .srv-duration {
    font-size: 12px;
    color: var(--ink-2);
    background: var(--cream);
    padding: 2px 8px;
    border-radius: 20px;
  }
  .srv-card h3 {
    font-family: var(--serif);
    font-size: 1.15rem;
    color: var(--navy);
    margin: 0;
  }
  .srv-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }
  .srv-features li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--ink-2);
  }
  .srv-features li svg {
    color: var(--gold);
    flex-shrink: 0;
  }
  .srv-cta {
    width: 100%;
    text-align: center;
    font-size: 13px;
    padding: 10px 0;
  }

  /* ── Process ──────────────────────────────────── */
  .process-section {
    padding: 100px 0;
    background: var(--cream);
  }
  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    margin-top: 56px;
  }
  .process-step {
    position: relative;
    padding-top: 20px;
  }
  .process-step::before {
    content: '';
    position: absolute;
    top: 32px;
    left: calc(100% - 16px);
    width: 50%;
    height: 2px;
    background: var(--line);
  }
  .process-grid > .process-step:last-child::before { display: none; }
  .step-num {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--navy);
    color: var(--gold);
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }
  .process-step h3 {
    font-family: var(--serif);
    font-size: 1.1rem;
    color: var(--navy);
    margin-bottom: 8px;
  }
  .process-step p {
    font-size: 14px;
    color: var(--ink-2);
    line-height: 1.65;
    margin: 0;
  }

  /* ── FAQ ──────────────────────────────────────── */
  .faq-section {
    padding: 100px 0;
    background: #fff;
  }
  .faq-list {
    margin-top: 56px;
    max-width: 780px;
    margin-left: auto;
    margin-right: auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .faq-item {
    border-bottom: 1px solid var(--line);
  }
  .faq-item:first-child {
    border-top: 1px solid var(--line);
  }
  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 22px 0;
    cursor: pointer;
    font-weight: 600;
    font-size: 16px;
    color: var(--navy);
    list-style: none;
    user-select: none;
    transition: color .15s;
  }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question:hover { color: var(--gold); }
  .faq-icon {
    flex-shrink: 0;
    color: var(--gold);
    transition: transform .25s ease;
  }
  .faq-item[open] .faq-icon {
    transform: rotate(180deg);
  }
  .faq-item[open] .faq-question {
    color: var(--gold);
  }
  .faq-answer {
    padding: 0 0 22px;
  }
  .faq-answer p {
    color: var(--ink-2);
    font-size: 15px;
    line-height: 1.75;
    margin: 0;
    max-width: 680px;
  }

  /* ── Responsive ───────────────────────────────── */
  @media (max-width: 900px) {
    .srv-grid { grid-template-columns: repeat(2, 1fr); }
    .process-grid { grid-template-columns: repeat(2, 1fr); }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .process-step::before { display: none; }
  }
  @media (max-width: 600px) {
    .srv-grid { grid-template-columns: 1fr; }
    .process-grid { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
