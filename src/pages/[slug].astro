---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import CTABand from '../components/CTABand.astro'
import Footer from '../components/Footer.astro'

import { createReader } from '@keystatic/core/reader'
import keystaticConfig from '../../keystatic.config'
import Markdoc from '@markdoc/markdoc'
import { categorySlug } from '../lib/blog'

export async function getStaticPaths() {
  try {
    const reader = createReader(process.cwd(), keystaticConfig)
    const slugs = await reader.collections.blog.list()
    return slugs.map((slug) => ({ params: { slug } }))
  } catch {
    return []
  }
}

const { slug } = Astro.params
const reader = createReader(process.cwd(), keystaticConfig)

let post: any = null
let renderedContent = ''

try {
  post = await reader.collections.blog.read(slug!)
  if (post?.content) {
    const { node } = await post.content()
    const transformed = Markdoc.transform(node)
    renderedContent = Markdoc.renderers.html(transformed)
  }
} catch {
  return Astro.redirect('/blog')
}

if (!post) return Astro.redirect('/blog')

const title = typeof post.title === 'object' ? (post.title as any).value ?? '' : post.title ?? ''

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('fr-FR', {
    day: 'numeric', month: 'long', year: 'numeric'
  })
}

// URLs de partage
const articleURL = `https://paul-alves.fr/${slug}`
const encodedURL   = encodeURIComponent(articleURL)
const encodedTitle = encodeURIComponent(title)
const shareLinks = {
  twitter:  `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedURL}`,
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedURL}`,
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodedURL}`,
  whatsapp: `https://api.whatsapp.com/send?text=${encodedTitle}%20${encodedURL}`,
}

// Articles similaires
let relatedPosts: { slug: string; title: string; description: string; publishedAt: string; category: string; image: string }[] = []
try {
  const allSlugs = await reader.collections.blog.list()
  const others = (await Promise.all(
    allSlugs
      .filter(s => s !== slug)
      .map(async s => {
        const e = await reader.collections.blog.read(s)
        return e ? { slug: s, ...e } : null
      })
  )).filter(Boolean) as any[]

  const sameCategory = others.filter(p => p.category === post.category)
  const different    = others.filter(p => p.category !== post.category)

  relatedPosts = [...sameCategory, ...different].slice(0, 3).map(p => ({
    slug:        p.slug,
    title:       typeof p.title === 'object' ? (p.title as any).value ?? '' : p.title ?? '',
    description: p.description ?? '',
    publishedAt: p.publishedAt ?? '',
    category:    p.category ?? '',
    image:       p.image ?? '',
  }))
} catch { /* pas d'articles similaires */ }

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": post.description ?? '',
  "datePublished": post.publishedAt ?? '',
  "url": `https://paul-alves.fr/${slug}`,
  "author": {
    "@type": "Person",
    "name": "Paul Alves",
    "url": "https://paul-alves.fr"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Paul Alves",
    "url": "https://paul-alves.fr"
  }
})
---

<Layout
  title={`${title} — Paul Alves`}
  description={post.description ?? ''}
  image={post.image ?? '/assets/hero-visual.png'}
  schema={articleSchema}
  ogType="article"
  publishedAt={post.publishedAt ?? undefined}
  section={post.category ?? undefined}
>
  <Nav currentPath="/blog" />

  <section class="article-hero">
    {post.image && (
      <div class="hero-bg">
        <img src={post.image} alt="" role="presentation" width="1200" height="630" />
      </div>
    )}
    <div class="hero-overlay" />
    <div class="wrap hero-content">
      <p class="eyebrow" style="text-align:left;">
        {post.category
          ? <a href={`/blog/categorie/${categorySlug(post.category)}/`} class="eyebrow-link">{post.category}</a>
          : 'Blog'}
      </p>
      <h1>{title}</h1>
      <p class="lede">{post.description}</p>
      <div class="article-meta">
        <span class="item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
          </svg>
          {formatDate(post.publishedAt ?? '')}
        </span>
        <span class="item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/>
          </svg>
          Paul Alves
        </span>
      </div>
    </div>
  </section>

  <div class="article-layout">
    <!-- Sommaire (sidebar desktop / bloc mobile) -->
    <aside class="article-toc" id="articleToc" aria-label="Sommaire de l'article">
      <p class="toc-title">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        Sommaire
      </p>
      <ol class="toc-list" id="tocList"></ol>
    </aside>

    <div class="article-body">
    <article class="article-content" set:html={renderedContent} />

    <!-- Partage réseaux sociaux -->
    <div class="share-section">
      <p class="share-label">Partager cet article</p>
      <div class="share-buttons">
        <a
          href={shareLinks.twitter}
          rel="nofollow noopener noreferrer"
          target="_blank"
          class="share-btn share-btn--twitter"
          aria-label="Partager sur X (Twitter)"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.26 5.632 5.905-5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          X
        </a>
        <a
          href={shareLinks.linkedin}
          rel="nofollow noopener noreferrer"
          target="_blank"
          class="share-btn share-btn--linkedin"
          aria-label="Partager sur LinkedIn"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
          LinkedIn
        </a>
        <a
          href={shareLinks.facebook}
          rel="nofollow noopener noreferrer"
          target="_blank"
          class="share-btn share-btn--facebook"
          aria-label="Partager sur Facebook"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
          Facebook
        </a>
        <a
          href={shareLinks.whatsapp}
          rel="nofollow noopener noreferrer"
          target="_blank"
          class="share-btn share-btn--whatsapp"
          aria-label="Partager sur WhatsApp"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.528 5.857L.057 23.12a.75.75 0 0 0 .923.899l5.356-1.538A11.943 11.943 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22.5c-1.92 0-3.735-.51-5.295-1.395l-.39-.226-3.812 1.095 1.038-3.71-.247-.403A10.44 10.44 0 0 1 1.5 12C1.5 6.201 6.201 1.5 12 1.5S22.5 6.201 22.5 12 17.799 22.5 12 22.5z"/>
          </svg>
          WhatsApp
        </a>
        <button class="share-btn share-btn--copy" id="copyBtn" aria-label="Copier le lien">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
          </svg>
          <span id="copyLabel">Copier le lien</span>
        </button>
      </div>
    </div>

    <div class="article-footer-nav">
      <a href="/blog" class="btn btn-outline" style="font-size: 13px; padding: 10px 18px;">
        ← Tous les articles
      </a>
      <a
        href="#"
        data-cal-link="paul-alves/audit-offert"
        data-cal-namespace="audit-offert"
        class="btn btn-gold"
        style="font-size: 13px; padding: 10px 18px;"
      >
        Travaillons ensemble
      </a>
    </div>
    </div><!-- /.article-body -->
  </div><!-- /.article-layout -->

  <!-- Articles similaires -->
  {relatedPosts.length > 0 && (
    <section class="related-section">
      <div class="wrap">
        <p class="section-eyebrow">Continuer la lecture</p>
        <h2 class="section-title">Articles <span class="accent">similaires</span></h2>
        <div class="related-grid">
          {relatedPosts.map(p => (
            <a href={`/${p.slug}`} class="related-card">
              <div class="related-card-img">
                {p.image
                  ? <img src={p.image} alt={p.title} width="400" height="220" loading="lazy" />
                  : <div class="related-card-placeholder" />
                }
              </div>
              <div class="related-card-body">
                {p.category && <span class="related-cat">{p.category}</span>}
                <h3>{p.title}</h3>
                <p>{p.description}</p>
                <span class="related-link">Lire l'article →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTABand />
  <Footer />
</Layout>

<style>
  /* ── Hero avec image de fond ───────────────────── */
  .article-hero {
    position: relative;
    overflow: hidden;
    padding: 110px 0 90px;
    min-height: 460px;
    display: flex;
    align-items: center;
  }
  /* Image floue en arrière-plan */
  .hero-bg {
    position: absolute;
    inset: -8%; /* débordement pour masquer les bords floutés */
    z-index: 0;
  }
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(10px);
  }
  /* Voile sombre pour la lisibilité */
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      160deg,
      rgba(10, 29, 54, 0.88) 0%,
      rgba(10, 29, 54, 0.80) 60%,
      rgba(10, 29, 54, 0.75) 100%
    );
  }
  /* Contenu texte au-dessus du voile */
  .hero-content {
    position: relative;
    z-index: 2;
  }
  .eyebrow-link {
    color: inherit;
    text-decoration: none;
    transition: opacity .15s;
  }
  .eyebrow-link:hover {
    opacity: .8;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Layout article + sommaire ────────────────── */
  .article-layout {
    max-width: 1160px;
    margin: 0 auto;
    padding: 64px 40px;
    display: grid;
    grid-template-columns: 232px minmax(0, 1fr);
    gap: 56px;
    align-items: start;
  }
  /* Neutralise le max-width centré du global.css */
  .article-body {
    max-width: none;
    margin: 0;
    padding: 0;
  }
  .article-layout.no-toc {
    grid-template-columns: 1fr;
    max-width: 820px;
  }

  /* ── Sommaire sidebar ──────────────────────────── */
  .article-toc {
    position: sticky;
    top: 90px;
    background: var(--cream);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 22px 20px;
  }
  .article-toc.toc-hidden { display: none; }
  .toc-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--navy);
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--line);
  }
  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .toc-item { margin: 0; }
  .toc-h3 { padding-left: 14px; }
  .toc-link {
    display: block;
    padding: 5px 10px;
    border-radius: 6px;
    color: var(--ink-2);
    text-decoration: none;
    font-size: 13px;
    line-height: 1.45;
    border-left: 2px solid transparent;
    transition: color .15s, background .15s, border-color .15s;
  }
  .toc-link:hover {
    color: var(--navy);
    background: rgba(10,29,54,.05);
  }
  .toc-link.toc-active {
    color: var(--gold);
    font-weight: 600;
    border-left-color: var(--gold);
    background: rgba(212,164,74,.07);
  }

  /* ── Responsive ────────────────────────────────── */
  @media (max-width: 960px) {
    .article-layout {
      grid-template-columns: 1fr;
      padding: 40px 20px;
      gap: 0;
    }
    .article-toc {
      position: static;
      margin-bottom: 36px;
    }
  }

  /* ── Partage ───────────────────────────────────── */
  .share-section {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--line);
  }
  .share-label {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--ink-2);
    margin-bottom: 14px;
  }
  .share-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 16px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: opacity .15s, transform .15s;
    white-space: nowrap;
    font-family: inherit;
  }
  .share-btn:hover { opacity: .85; transform: translateY(-1px); }
  .share-btn--twitter  { background: #000;      color: #fff; }
  .share-btn--linkedin { background: #0a66c2;   color: #fff; }
  .share-btn--facebook { background: #1877f2;   color: #fff; }
  .share-btn--whatsapp { background: #25d366;   color: #fff; }
  .share-btn--copy     { background: var(--cream); color: var(--navy); border: 1px solid var(--line); }
  .share-btn--copy.copied { background: var(--navy); color: #fff; border-color: var(--navy); }

  /* ── Navigation bas d'article ──────────────────── */
  .article-footer-nav {
    margin-top: 28px;
    padding-top: 28px;
    border-top: 1px solid var(--line);
    display: flex;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
  }

  /* ── Articles similaires ───────────────────────── */
  .related-section {
    background: var(--cream);
    padding: 80px 0 100px;
    border-top: 1px solid var(--line);
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }
  .related-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: box-shadow .2s, transform .2s;
  }
  .related-card:hover {
    box-shadow: 0 10px 36px rgba(10,29,54,.09);
    transform: translateY(-3px);
  }
  .related-card-img {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--cream);
  }
  .related-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .4s ease;
  }
  .related-card:hover .related-card-img img { transform: scale(1.04); }
  .related-card-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--cream) 0%, #e8e2d9 100%);
  }
  .related-card-body {
    padding: 22px 24px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }
  .related-cat {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--gold);
  }
  .related-card-body h3 {
    font-family: var(--serif);
    font-size: 1rem;
    color: var(--navy);
    line-height: 1.35;
    margin: 0;
  }
  .related-card-body p {
    font-size: 13px;
    color: var(--ink-2);
    line-height: 1.6;
    margin: 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .related-link {
    font-size: 13px;
    font-weight: 600;
    color: var(--gold);
    margin-top: 4px;
  }
  @media (max-width: 900px) {
    .related-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .related-grid { grid-template-columns: 1fr; }
    .share-buttons { gap: 8px; }
    .share-btn { padding: 8px 12px; font-size: 12px; }
  }
</style>

<script>
  // ── Génération automatique du sommaire ───────────
  const content  = document.querySelector('.article-content')
  const tocList  = document.getElementById('tocList')
  const toc      = document.getElementById('articleToc')
  const layout   = document.querySelector('.article-layout')

  if (content && tocList && toc) {
    const headings = [...content.querySelectorAll('h2, h3')]

    if (headings.length < 2) {
      // Pas assez de titres : on masque le sommaire et on repasse en 1 colonne
      toc.classList.add('toc-hidden')
      layout?.classList.add('no-toc')
    } else {
      // Slugification robuste (accents, caractères spéciaux)
      const slugify = (text: string) =>
        text.toLowerCase()
            .normalize('NFD').replace(/[̀-ͯ]/g, '')
            .replace(/[^\w\s-]/g, '').trim()
            .replace(/\s+/g, '-').replace(/-+/g, '-')

      const used: Record<string, number> = {}

      headings.forEach((h, i) => {
        const text = h.textContent?.trim() ?? ''
        let id = slugify(text) || `section-${i}`
        if (used[id] !== undefined) { used[id]++; id += `-${used[id]}` } else { used[id] = 0 }
        h.id = id

        const li = document.createElement('li')
        li.className = `toc-item toc-${h.tagName.toLowerCase()}`

        const a = document.createElement('a')
        a.href = `#${id}`
        a.textContent = text
        a.className = 'toc-link'
        a.addEventListener('click', (e) => {
          e.preventDefault()
          const target = document.getElementById(id)
          if (target) {
            const top = target.getBoundingClientRect().top + window.scrollY - 90
            window.scrollTo({ top, behavior: 'smooth' })
          }
        })

        li.appendChild(a)
        tocList.appendChild(li)
      })

      // Surlignage du titre actif au scroll
      const links = tocList.querySelectorAll<HTMLAnchorElement>('.toc-link')
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            links.forEach(l => l.classList.remove('toc-active'))
            tocList.querySelector(`a[href="#${entry.target.id}"]`)
                   ?.classList.add('toc-active')
          }
        })
      }, { rootMargin: '-80px 0px -70% 0px', threshold: 0 })

      headings.forEach(h => observer.observe(h))
    }
  }
</script>

<script>
  // Bouton "Copier le lien"
  const copyBtn = document.getElementById('copyBtn')
  const copyLabel = document.getElementById('copyLabel')
  if (copyBtn && copyLabel) {
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href)
        copyLabel.textContent = 'Lien copié !'
        copyBtn.classList.add('copied')
        setTimeout(() => {
          copyLabel.textContent = 'Copier le lien'
          copyBtn.classList.remove('copied')
        }, 2000)
      } catch {
        // fallback silencieux
      }
    })
  }
</script>

<script>
  (function(C: any, A: string, L: string) {
    const p = (a: any, ar: any) => a.q.push(ar)
    const d = (C as any).document
    ;(C as any).Cal = (C as any).Cal || function() {
      const cal = (C as any).Cal
      const ar = arguments as any
      if (!cal.loaded) {
        cal.ns = {}; cal.q = cal.q || []
        d.head.appendChild(d.createElement('script')).src = A
        cal.loaded = true
      }
      if (ar[0] === L) {
        const api: any = function() { p(api, arguments) }
        const namespace = ar[1]
        api.q = api.q || []
        typeof namespace === 'string' ? (cal.ns[namespace] = api) && p(api, ar) : p(cal, ar)
        return
      }
      p(cal, ar)
    }
  })(window, 'https://app.cal.eu/embed/embed.js', 'init')
  ;(window as any).Cal('init', 'audit-offert', { origin: 'https://cal.eu' })
</script>
