---
import Layout from '../../layouts/Layout.astro'
import Nav from '../../components/Nav.astro'
import CTABand from '../../components/CTABand.astro'
import Footer from '../../components/Footer.astro'

import { createReader } from '@keystatic/core/reader'
import keystaticConfig from '../../../keystatic.config'
import Markdoc from '@markdoc/markdoc'

export async function getStaticPaths() {
  try {
    const reader = createReader(process.cwd(), keystaticConfig)
    const slugs = await reader.collections.blog.list()
    return slugs.map((slug) => ({ params: { slug } }))
  } catch {
    return []
  }
}

const { slug } = Astro.params
const reader = createReader(process.cwd(), keystaticConfig)

let post: any = null
let renderedContent = ''

try {
  post = await reader.collections.blog.read(slug!)
  if (post?.content) {
    const { node } = await post.content()
    const transformed = Markdoc.transform(node)
    renderedContent = Markdoc.renderers.html(transformed)
  }
} catch {
  return Astro.redirect('/blog')
}

if (!post) return Astro.redirect('/blog')

const title = typeof post.title === 'object' ? (post.title as any).value ?? '' : post.title ?? ''

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('fr-FR', {
    day: 'numeric', month: 'long', year: 'numeric'
  })
}

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": post.description ?? '',
  "datePublished": post.publishedAt ?? '',
  "url": `https://paul-alves.fr/blog/${slug}`,
  "author": {
    "@type": "Person",
    "name": "Paul Alves",
    "url": "https://paul-alves.fr"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Paul Alves",
    "url": "https://paul-alves.fr"
  }
})
---

<Layout
  title={`${title} — Paul Alves`}
  description={post.description ?? ''}
  image={post.image ?? '/assets/hero-visual.png'}
  schema={articleSchema}
>
  <Nav currentPath="/blog" />

  <section class="article-hero">
    <div class="wrap">
      <p class="eyebrow" style="text-align:left;">
        {post.category ?? 'Blog'}
      </p>
      <h1>{title}</h1>
      <p class="lede">{post.description}</p>
      <div class="article-meta">
        <span class="item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
          </svg>
          {formatDate(post.publishedAt ?? '')}
        </span>
        <span class="item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/>
          </svg>
          Paul Alves
        </span>
      </div>
    </div>
  </section>

  {post.image && (
    <div class="article-cover">
      <img src={post.image} alt={title} width="1200" height="450" />
    </div>
  )}

  <div class="article-body">
    <article class="article-content" set:html={renderedContent} />

    <div style="margin-top: 48px; padding-top: 32px; border-top: 1px solid var(--line); display: flex; gap: 16px; align-items: center;">
      <a href="/blog" class="btn btn-outline" style="font-size: 13px; padding: 10px 18px;">
        ← Tous les articles
      </a>
      <a
        href="#"
        data-cal-link="paul-alves/audit-offert"
        data-cal-namespace="audit-offert"
        class="btn btn-gold"
        style="font-size: 13px; padding: 10px 18px;"
      >
        Travaillons ensemble
      </a>
    </div>
  </div>

  <CTABand />
  <Footer />
</Layout>

<script>
  (function(C: any, A: string, L: string) {
    const p = (a: any, ar: any) => a.q.push(ar)
    const d = (C as any).document
    ;(C as any).Cal = (C as any).Cal || function() {
      const cal = (C as any).Cal
      const ar = arguments as any
      if (!cal.loaded) {
        cal.ns = {}; cal.q = cal.q || []
        d.head.appendChild(d.createElement('script')).src = A
        cal.loaded = true
      }
      if (ar[0] === L) {
        const api: any = function() { p(api, arguments) }
        const namespace = ar[1]
        api.q = api.q || []
        typeof namespace === 'string' ? (cal.ns[namespace] = api) && p(api, ar) : p(cal, ar)
        return
      }
      p(cal, ar)
    }
  })(window, 'https://app.cal.eu/embed/embed.js', 'init')
  ;(window as any).Cal('init', 'audit-offert', { origin: 'https://cal.eu' })
</script>
