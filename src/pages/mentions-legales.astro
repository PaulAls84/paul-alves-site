---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
---

<Layout
  title="Mentions légales — Paul Alves"
  description="Mentions légales du site paul-alves.fr — informations légales et éditoriales."
>
  <Nav />

  <section style="padding: 80px 0 120px;">
    <div class="wrap" style="max-width: 760px;">
      <p class="eyebrow" style="text-align:left;">Légal</p>
      <h1 style="margin-bottom: 48px;">Mentions légales</h1>

      <div class="legal-content">

