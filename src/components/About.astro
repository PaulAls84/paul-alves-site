<section id="apropos" style="padding-top: 24px;">
  <div class="wrap">
    <div class="about-grid">
      <div class="about-photo">
        <img
          src="/assets/photo-paul.png"
          alt="Portrait de Paul Alves"
          width="360" height="432"
        />
      </div>

      <div class="about-body">
        <p class="eyebrow">À propos</p>
        <h2>Qui suis-je ?</h2>
        <p>
          Je suis Paul Alves, développeur web et consultant SEO passionné par le digital et les
          résultats. Basé à Soissons, j'accompagne des entreprises partout en France.
        </p>
        <p>
          J'aide les entreprises et entrepreneurs dans la création de sites web efficaces et dans
          l'optimisation de leur référencement pour générer plus de trafic et de conversions.
        </p>
        <ul class="about-list">
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="9"/><path d="m8 12 3 3 5-6"/>
            </svg>
            Plus de 5 ans d'expérience
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="9"/><path d="m8 12 3 3 5-6"/>
            </svg>
            Des solutions sur mesure
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="9"/><path d="m8 12 3 3 5-6"/>
            </svg>
            Un seul objectif : vos résultats
          </li>
        </ul>
        <a href="/#contact" class="btn btn-navy">Me contacter</a>
      </div>
    </div>
  </div>
</section>
