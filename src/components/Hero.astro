<section class="hero" id="accueil" style="padding: 0;">
  <div class="wrap">
    <div class="hero-grid">
      <div>
        <p class="eyebrow">Développeur Web &amp; Consultant SEO</p>
        <h1>
          Des sites performants.<br />
          Un meilleur référencement.<br />
          Plus de <span class="accent">résultats.</span>
        </h1>
        <p class="lede">
          J'aide les entreprises à se développer en ligne grâce à des sites web sur mesure,
          rapides et optimisés pour le SEO.
        </p>
        <div class="cta-row">
          <a
            href="#"
            data-cal-link="paul-alves/audit-offert"
            data-cal-namespace="audit-offert"
            data-cal-config='{"layout":"month_view"}'
            class="btn btn-gold"
          >
            Réserver un appel gratuit →
          </a>
          <a href="tel:+33656666684" class="btn btn-ghost-light hero-tel">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
            </svg>
            06 56 66 66 84
          </a>
        </div>
        <div class="trust-row">
          <span class="item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="9"/><path d="m8 12 3 3 5-6"/>
            </svg>
            Sites rapides &amp; sécurisés
          </span>
          <span class="item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 20h18M5 17V9M9 17V5M13 17v-7M17 17V7m-13-4 5-6 4 4 8-8"/>
            </svg>
            SEO technique &amp; contenu
          </span>
          <span class="item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/>
            </svg>
            Accompagnement personnalisé
          </span>
        </div>
      </div>

      <div class="hero-visual">
        <img
          src="/assets/hero-visual.webp"
          alt="Paul Alves — Développeur Web & Consultant SEO"
          width="600" height="450"
          fetchpriority="high"
        />
      </div>
    </div>
  </div>
</section>
